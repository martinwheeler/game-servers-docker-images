#!/bin/bash
set -euo pipefail

DOCKER_REPO="martingwheeler/terraria"
TERRARIA_VERSION="${TERRARIA_VERSION:-$(./scripts/get-terraria-version.sh)}"

echo "Building ${DOCKER_REPO} (${TERRARIA_VERSION})..."

docker build --no-cache \
  --build-arg TERRARIA_VERSION="${TERRARIA_VERSION}" \
  -t "${DOCKER_REPO}:latest" \
  -t "${DOCKER_REPO}:${TERRARIA_VERSION}" \
  .

echo "Build complete: ${DOCKER_REPO}:${TERRARIA_VERSION} and ${DOCKER_REPO}:latest"
