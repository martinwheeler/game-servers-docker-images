#!/bin/bash
set -euo pipefail

DOCKER_REPO="servertimeio/minecraft"
MINECRAFT_VERSION="${MINECRAFT_VERSION:-$(./scripts/get-minecraft-version.sh)}"
PAPER_BUILD="${PAPER_BUILD:-$(./scripts/get-paper-build.sh)}"
IMAGE_TAG="${MINECRAFT_VERSION}-paper-${PAPER_BUILD}"

echo "Building ${DOCKER_REPO} (${IMAGE_TAG})..."

docker build --no-cache \
  --build-arg MINECRAFT_VERSION="${MINECRAFT_VERSION}" \
  --build-arg PAPER_BUILD="${PAPER_BUILD}" \
  -t "${DOCKER_REPO}:latest" \
  -t "${DOCKER_REPO}:${IMAGE_TAG}" \
  .

echo "Build complete: ${DOCKER_REPO}:${IMAGE_TAG} and ${DOCKER_REPO}:latest"
